<?xml version="1.0" encoding="utf-8"?>
<!--
  THE SYSTEM — network policy.

  HTTPS is enforced by default. Cleartext (HTTP) is only permitted for local
  dev hosts (emulator loopback, LAN IPs). The deployed Render backend uses
  HTTPS and is trusted via the system CA store.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Production backend (Render) — HTTPS, trusted by system CAs -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">onrender.com</domain>
    </domain-config>

    <!-- Local dev backend only. Extend or shrink to match your LAN. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>       <!-- Android emulator → host localhost -->
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <!-- Common home-router LAN ranges. Trim to just your PC's IP for tighter security. -->
        <domain-suffix includeSubdomains="true">192.168.1.1</domain-suffix>
        <domain-suffix includeSubdomains="true">192.168.0.1</domain-suffix>
    </domain-config>
</network-security-config>
