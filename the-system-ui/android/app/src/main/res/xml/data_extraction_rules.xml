<?xml version="1.0" encoding="utf-8"?>
<!--
  THE SYSTEM — Android 12+ backup / device-transfer opt-out.
  Disables Auto Backup to Google Drive AND device-to-device transfer so the
  Hunter's JWT + Life OS data never leave the phone.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>

