<?xml version="1.0" encoding="utf-8"?>
<!-- Premium "deep space" adaptive-icon background for THE SYSTEM.
     Radial violet glow over a near-black gradient with faint tech grid. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Base diagonal gradient -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0" android:startY="0"
                android:endX="108" android:endY="108">
                <item android:offset="0.0" android:color="#FF150C33" />
                <item android:offset="0.55" android:color="#FF0A0A18" />
                <item android:offset="1.0" android:color="#FF05050D" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Central radial glow behind the emblem -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54" android:centerY="50"
                android:gradientRadius="62">
                <item android:offset="0.0" android:color="#556C63FF" />
                <item android:offset="0.5" android:color="#22534AB7" />
                <item android:offset="1.0" android:color="#00000000" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Faint tech grid lines -->
    <path android:fillColor="#00000000" android:pathData="M27,0L27,108" android:strokeColor="#14FFFFFF" android:strokeWidth="0.6" />
    <path android:fillColor="#00000000" android:pathData="M81,0L81,108" android:strokeColor="#14FFFFFF" android:strokeWidth="0.6" />
    <path android:fillColor="#00000000" android:pathData="M0,27L108,27" android:strokeColor="#14FFFFFF" android:strokeWidth="0.6" />
    <path android:fillColor="#00000000" android:pathData="M0,81L108,81" android:strokeColor="#14FFFFFF" android:strokeWidth="0.6" />
</vector>
