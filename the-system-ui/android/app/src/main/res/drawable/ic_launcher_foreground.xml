<?xml version="1.0" encoding="utf-8"?>
<!-- THE SYSTEM emblem — a glowing "Monarch Gate" diamond with an
     upward level-up chevron. Vector = crisp at every density. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Soft outer glow (large, low-opacity diamond) -->
    <path android:pathData="M54,16 L92,54 L54,92 L16,54 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial"
                android:centerX="54" android:centerY="54" android:gradientRadius="46">
                <item android:offset="0.0" android:color="#556C63FF" />
                <item android:offset="0.7" android:color="#1A4FC3F7" />
                <item android:offset="1.0" android:color="#00000000" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Inner diamond glass fill -->
    <path android:pathData="M54,26 L82,54 L54,82 L26,54 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="26" android:startY="26" android:endX="82" android:endY="82">
                <item android:offset="0.0" android:color="#332A2470" />
                <item android:offset="1.0" android:color="#11101020" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Diamond outline (violet -> cyan gradient stroke) -->
    <path android:pathData="M54,25 L83,54 L54,83 L25,54 Z"
        android:fillColor="#00000000" android:strokeWidth="3.2">
        <aapt:attr name="android:strokeColor">
            <gradient android:type="linear"
                android:startX="25" android:startY="25" android:endX="83" android:endY="83">
                <item android:offset="0.0" android:color="#FF8B83FF" />
                <item android:offset="0.5" android:color="#FF6C63FF" />
                <item android:offset="1.0" android:color="#FF4FC3F7" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Upper level-up chevron -->
    <path android:pathData="M40,56 L54,42 L68,56"
        android:fillColor="#00000000" android:strokeWidth="4.6"
        android:strokeLineCap="round" android:strokeLineJoin="round">
        <aapt:attr name="android:strokeColor">
            <gradient android:type="linear"
                android:startX="40" android:startY="42" android:endX="68" android:endY="56">
                <item android:offset="0.0" android:color="#FF6FE3FF" />
                <item android:offset="1.0" android:color="#FFB9F0FF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Lower level-up chevron -->
    <path android:pathData="M40,66 L54,52 L68,66"
        android:fillColor="#00000000" android:strokeWidth="4.6"
        android:strokeLineCap="round" android:strokeLineJoin="round"
        android:strokeColor="#CC4FC3F7" />

    <!-- Apex spark -->
    <path android:pathData="M54,30 m-2.4,0 a2.4,2.4 0 1,0 4.8,0 a2.4,2.4 0 1,0 -4.8,0"
        android:fillColor="#FFEAF7FF" />
</vector>

