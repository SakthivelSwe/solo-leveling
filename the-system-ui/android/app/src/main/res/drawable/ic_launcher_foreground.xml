<?xml version="1.0" encoding="utf-8"?>
<!-- THE SYSTEM emblem — a solid "Monarch Gate" diamond with a bold double
     level-up chevron. Solid fills (not thin outlines) so it stays crisp and
     legible at every launcher size and on any background. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Soft outer glow -->
    <path android:pathData="M54,14 L94,54 L54,94 L14,54 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial"
                android:centerX="54" android:centerY="54" android:gradientRadius="48">
                <item android:offset="0.0" android:color="#886C63FF" />
                <item android:offset="0.7" android:color="#334FC3F7" />
                <item android:offset="1.0" android:color="#00000000" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Solid diamond gate (violet -> cyan) -->
    <path android:pathData="M54,22 L86,54 L54,86 L22,54 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="24" android:startY="24" android:endX="84" android:endY="84">
                <item android:offset="0.0" android:color="#FF8B83FF" />
                <item android:offset="0.5" android:color="#FF6C63FF" />
                <item android:offset="1.0" android:color="#FF3CB4F5" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Inner glass highlight (top-left) -->
    <path android:pathData="M54,28 L80,54 L54,54 L36,54 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="54" android:startY="28" android:endX="54" android:endY="54">
                <item android:offset="0.0" android:color="#55FFFFFF" />
                <item android:offset="1.0" android:color="#00FFFFFF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Bold upper level-up chevron -->
    <path android:pathData="M38,58 L54,42 L70,58"
        android:fillColor="#00000000" android:strokeColor="#FFFFFFFF"
        android:strokeWidth="6.5" android:strokeLineCap="round" android:strokeLineJoin="round" />

    <!-- Lower level-up chevron -->
    <path android:pathData="M38,70 L54,54 L70,70"
        android:fillColor="#00000000" android:strokeColor="#CCEAF7FF"
        android:strokeWidth="6.5" android:strokeLineCap="round" android:strokeLineJoin="round" />
</vector>
