# ── THE SYSTEM · local secrets (git-ignored) ────────────────────────────────
# Copy this file to application-local.yml and fill in your real values.
# Do NOT commit application-local.yml!
thesystem:
  dev-tools-enabled: true
  jwt:
    secret: "CHANGE-ME-generate-with-openssl-rand-base64-48"
  ai:
    groq-api-key: "YOUR_GROQ_API_KEY_HERE"
    gemini-api-key: "YOUR_GEMINI_API_KEY_HERE"

spring:
  datasource:
    url: jdbc:postgresql://YOUR_SUPABASE_HOST:5432/postgres
    username: YOUR_SUPABASE_USERNAME
    password: YOUR_SUPABASE_PASSWORD
